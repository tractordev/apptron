#!/bin/busybox sh

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t binfmt_misc none /proc/sys/fs/binfmt_misc

# register wasm binary format
echo ':wasm:M::\x00\x61\x73\x6d::/bin/wexec:' > /proc/sys/fs/binfmt_misc/register

# loads apptron.sh for ENV_UUID, SESSION_IP
source /etc/profile 

# configure loopback networking
ifconfig lo up

# if embedded and no user, skip network/dhcp setup
if [ "$ENV_EMBED" == "0" ] && [ -n "$USER" ]; then
    ifconfig eth0 up
    udhcpc -i eth0 -s /bin/post-dhcp
    export SESSION_IP=$(ifconfig eth0 | grep "inet addr" | cut -d: -f2 | cut -d' ' -f1)
fi

envbuild_file=""
if [ -f /project/.apptron/envbuild ]; then
    envbuild_file=/project/.apptron/envbuild
elif [ -f /project/.envbuild ]; then
    envbuild_file=/project/.envbuild
fi
if [ -n "$envbuild_file" ]; then
    env_overlay=/web/idbfs/apptron/env/$ENV_UUID/overlay
    # if overlay doesn't exist or is older than envbuild, rebuild
    if [ ! -e $env_overlay ] || [ $envbuild_file -nt $env_overlay ]; then
        echo
        exec /bin/rebuild
    fi
fi

if [ ! -f /web/idbfs/apptron/.welcomed ]; then
    /bin/open /apptron/WELCOME.md
    touch /web/idbfs/apptron/.welcomed
fi

/bin/aptn ports &
# /bin/aptn fuse &

exec /bin/start
